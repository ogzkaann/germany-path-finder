{
  "name": "germany-path-finder",
  "version": "0.1.0",
  "description": "Local-first RAG portfolio MVP for source-backed residence and career path exploration in Germany.",
  "homepage": "https://github.com/ogzkaann/germany-path-finder#readme",
  "keywords": [
    "rag",
    "local-first",
    "react",
    "vite",
    "typescript",
    "indexeddb",
    "pdfjs",
    "byok",
    "germany",
    "portfolio"
  ],
  "private": true,
  "type": "module",
  "scripts": {
    "generate:knowledge": "node scripts/generate-knowledge-manifest.mjs && node scripts/generate-sample-user-vault-manifest.mjs",
    "dev": "npm run generate:knowledge && vite --host 127.0.0.1",
    "build": "npm run generate:knowledge && tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.0.11",
    "lucide-react": "^0.468.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
